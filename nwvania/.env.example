# ─── Email (Resend) ───────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Destination email for contact and early-access form submissions
CONTACT_EMAIL=you@example.com

# ─── Logging ──────────────────────────────────────────────────
# Random secret used to hash IP addresses in logs (GDPR compliance)
# Generate with: openssl rand -hex 32
LOG_IP_SALT=change-this-to-a-random-secret-string

# ─── Sentry (Error Tracking) ──────────────────────────────────
# Create a project at https://sentry.io and fill these in
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzz
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Generate at https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
